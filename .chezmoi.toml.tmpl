# Chezmoi configuration
# This file is templated and will be processed on apply

[data]
    name = "{{ .name }}"
    email = "{{ .email }}"

[diff]
    pager = "cat"

[merge]
    command = "vimdiff"

[edit]
{{- if and (eq .chezmoi.os "darwin") (lookPath "code") }}
    command = "code"
    args = ["--wait"]
{{- else }}
    command = {{ env "EDITOR" | default "nano" | quote }}
{{- end }}
