#!/usr/bin/env bash
# One-time initial setup: Zinit plugin manager & Powerline fonts
# This script runs only once after the first chezmoi apply

set -e

# ============================================================
# Helpers
# ============================================================
is_mac() { [[ "$OSTYPE" == "darwin"* ]]; }
is_linux() { [[ "$OSTYPE" == "linux"* ]]; }

# ============================================================
# Zinit Plugin Manager
# ============================================================
setup_zinit() {
    local zinit_home="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"

    if [[ -d "$zinit_home/.git" ]]; then
        echo "  ✓ Zinit already installed"
        return 0
    fi

    echo "  → Installing Zinit plugin manager..."
    mkdir -p "$(dirname "$zinit_home")"

    if git clone --depth=1 https://github.com/zdharma-continuum/zinit.git "$zinit_home"; then
        echo "  ✓ Zinit installed successfully"
    else
        echo "  ⚠️  Failed to install Zinit"
        return 1
    fi
}

# ============================================================
# SSH Keychain (macOS only)
# ============================================================
SSH_KEYS_MISSING=0

setup_ssh_keychain() {
    if ! is_mac; then return 0; fi

    local added=0
    for key in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa"; do
        [[ -f "$key" ]] || continue
        chmod 600 "$key"
        if ssh-add --apple-use-keychain "$key"; then
            echo "  ✓ Added $key to Keychain"
            added=1
        else
            echo "  ⚠️  Failed to add $key to Keychain"
        fi
    done

    if [[ $added -eq 0 ]]; then
        echo "  ⚠️  No SSH keys found — skipping"
        SSH_KEYS_MISSING=1
    fi
}

# ============================================================
# Powerline Fonts (MesloLGS NF)
# ============================================================
setup_fonts() {
    local font_dir
    
    # Determine font directory based on OS
    if is_mac; then
        font_dir="$HOME/Library/Fonts"
    elif is_linux; then
        font_dir="$HOME/.local/share/fonts"
    else
        echo "  ⚠️  Unknown OS, skipping font installation"
        return 0
    fi
    
    # Check if fonts are already installed
    if [[ -f "$font_dir/MesloLGS NF Regular.ttf" ]]; then
        echo "  ✓ MesloLGS NF fonts already installed"
        return 0
    fi
    
    echo "  → Installing MesloLGS NF fonts for Powerlevel10k..."
    mkdir -p "$font_dir"
    
    local base_url="https://github.com/romkatv/powerlevel10k-media/raw/master"
    local variants=("Regular" "Bold" "Italic" "Bold Italic")
    
    for variant in "${variants[@]}"; do
        local filename="MesloLGS NF ${variant}.ttf"
        local url="${base_url}/${filename// /%20}"
        
        if curl -fsSL "$url" -o "$font_dir/$filename"; then
            echo "    ✓ Installed $filename"
        else
            echo "    ⚠️  Failed to download $filename"
        fi
    done
    
    # Refresh font cache on Linux
    if is_linux && command -v fc-cache &>/dev/null; then
        echo "  → Refreshing font cache..."
        fc-cache -f "$font_dir" 2>/dev/null || true
    fi
    
    echo "  ✓ Font installation complete"
}

# ============================================================
# Main
# ============================================================
main() {
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Initial Setup (runs once)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    echo "📦 Setting up Zinit..."
    setup_zinit
    echo ""

    echo "🔑 Setting up SSH Keychain..."
    setup_ssh_keychain
    echo ""

    echo "🔤 Setting up fonts..."
    setup_fonts
    echo ""
    
    echo "✅ Initial setup complete!"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if [[ "$SSH_KEYS_MISSING" -eq 1 ]]; then
        echo ""
        echo "⚠️  ACTION REQUIRED: No SSH keys were found."
        echo "   Generate a key and add it to your GitHub/GitLab account:"
        echo ""
        echo "   ssh-keygen -t ed25519 -C \"$(git config user.email)\""
        echo "   ssh-add --apple-use-keychain ~/.ssh/id_ed25519"
        echo "   pbcopy < ~/.ssh/id_ed25519.pub"
        echo ""
    fi
}

main "$@"

